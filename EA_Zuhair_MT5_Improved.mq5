//+------------------------------------------------------------------+\n//|                                                 EA_Zuhair_MT5_Improved.mq5 |\n//|                        Copyright 2026, zuhair12345                  |\n//|                                       https://www.example.com        |\n//+------------------------------------------------------------------+\n\ninput double LotSize = 0.1; // Default lot size\ninput int Slippage = 3; // Default slippage\ninput double TakeProfit = 50; // Take profit in points\ninput double StopLoss = 50; // Stop loss in points\n\n// Global variables\nint handle; // Handle for indicator\nbool sessionOpen = false; // Indicator session flag\n\n//+------------------------------------------------------------------+\n//| Expert initialization function                                      |\n//+------------------------------------------------------------------+\nint OnInit() {\n    // Initialize indicator handle\n    handle = iSomeIndicator(Symbol(), Period());\n    if (handle == INVALID_HANDLE) {\n        Print("Failed to get indicator handle.");\n        return INIT_FAILED;\n    }\n\n    // Check if trading is allowed for the current symbol\n    if (!IsTradeAllowed(Symbol())) {\n        Print("Trading not allowed for symbol: " + Symbol());\n        Cleanup();\n        return INIT_FAILED;\n    }\n\n    // Check session validity\n    if (!CheckTradingSession()) {\n        Print("Trading session is not valid.");\n        Cleanup();\n        return INIT_FAILED;\n    }\n\n    return INIT_SUCCEEDED;\n}\n\n//+------------------------------------------------------------------+\n//| Expert deinitialization function                                    |\n//+------------------------------------------------------------------+\nvoid OnDeinit(const int reason) {\n    Cleanup(); // Clean up resources\n}\n\n//+------------------------------------------------------------------+\n//| Cleanup function                                                   |\n//+------------------------------------------------------------------+\nvoid Cleanup() {\n    if (handle != INVALID_HANDLE) {\n        IndicatorRelease(handle);\n        handle = INVALID_HANDLE;\n    }\n}\n\n//+------------------------------------------------------------------+\n//| Validate Ask/Bid prices                                           |\n//+------------------------------------------------------------------+\nbool ValidatePrices() {\n    double ask = SymbolInfoDouble(Symbol(), SYMBOL_ASK);\n    double bid = SymbolInfoDouble(Symbol(), SYMBOL_BID);\n    return (ask > 0 && bid > 0 && ask > bid);\n}\n\n//+------------------------------------------------------------------+\n//| Validate lot size boundaries                                       |\n//+------------------------------------------------------------------+\nbool ValidateLotSize(double lotSize) {\n    double minLot = SymbolInfoDouble(Symbol(), SYMBOL_VOLUME_MIN);\n    double maxLot = SymbolInfoDouble(Symbol(), SYMBOL_VOLUME_MAX);\n    return (lotSize >= minLot && lotSize <= maxLot);\n}\n\n//+------------------------------------------------------------------+\n//| Execute trade with error verification                              |\n//+------------------------------------------------------------------+\nbool ExecuteTrade(int action) {\n    double price = (action == OP_BUY) ? SymbolInfoDouble(Symbol(), SYMBOL_ASK) : SymbolInfoDouble(Symbol(), SYMBOL_BID);\n    double sl = (action == OP_BUY) ? price - StopLoss * _Point : price + StopLoss * _Point;\n    double tp = (action == OP_BUY) ? price + TakeProfit * _Point : price - TakeProfit * _Point;\n\n    if (!ValidatePrices()) {\n        Print("Invalid Ask/Bid prices.");\n        return false;\n    }\n\n    if (!ValidateLotSize(LotSize)) {\n        Print("Lot size invalid!" + LotSize);\n        return false;\n    }\n\n    int ticket = OrderSend(Symbol(), action, LotSize, price, Slippage, sl, tp, NULL);\n    if (ticket < 0) {\n        Print("Error executing trade: " + GetLastError());\n        return false;\n    }\n\n    return true;\n}\n\n//+------------------------------------------------------------------+\n//| Check trading session validity                                      |\n//+------------------------------------------------------------------+\nbool CheckTradingSession() {\n    datetime serverTime = TimeCurrent();\n    // Example session check (modify as needed)\n    datetime startTime = StringToTime("08:00");\n    datetime endTime = StringToTime("17:00");\n    return (serverTime >= startTime && serverTime <= endTime);\n}\n\n//+------------------------------------------------------------------+\n//| Main execution function                                            |\n//+------------------------------------------------------------------+\nvoid OnTick() {\n    // Add your trading logic here\n    if (ValidatePrices()) {\n        // Your trading logic using ExecuteTrade()\n    }\n}